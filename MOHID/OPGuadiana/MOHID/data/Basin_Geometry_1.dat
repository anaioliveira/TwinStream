!MOHID Studio Sample Data File
!This file contains the most common options.
!MODULE: Basin Geometry
!Please complete and comment/uncomment for your specific needs
!
!
!

!
!Values found in this file must be consistent with values used during watershed delineation
!
!Compute Options
TRESHOLD_AREA             : 50000000        !minimum area to define first reach
DELINEATE_BASIN           : 0              !connect/disconnect delineation (only watershed points will be active)
OUTLET_I                  : 26             !location of the outlet for delineation
OUTLET_J                  : 45             !location of the outlet for delineation
FLAT_SOLUTION             : 1
SET_RIVER_POINTS_FROM_DN  : 1
