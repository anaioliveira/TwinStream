<begin_file>
ACTION                        : INTERPOLATE GRIDS
TYPE_OF_INTERPOLATION         :  3
!EXTRAPOLATE_2D                :  3
START                         : begin_date
END                           : end_date

! Xmin Ymin Xmax Ymax
INTERPOLATION_WINDOW          : -9.615 36.85 -6 43.87

<<begin_father>>
FATHER_FILENAME               : input_file
FATHER_GRID_FILENAME          : father_grid
LEVEL                         : 1
<<end_father>>

OUTPUTFILENAME                : output_file
NEW_GRID_FILENAME             : ..\..\Grids\DTM.dat

<<BeginFields>>
air temperature
wind velocity X
wind velocity Y
relative humidity
solar radiation
precipitation
<<EndFields>>
<end_file>
