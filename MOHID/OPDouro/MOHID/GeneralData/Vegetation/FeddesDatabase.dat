<beginfeddesdatabase>
VEGETATION_ID             : 0		    !Novegetation

FEDDES_H1                 : -0.1 ! Saturação – ponto onde começa o estresse por excesso de água
FEDDES_H2                 : -0.25 ! Limite superior da faixa ótima de extração
FEDDES_H3                 : -6.0 ! Limite inferior da faixa ótima de extração
FEDDES_H4                 : -30.0 ! Ponto de murcha permanente
<endfeddesdatabase>

<beginfeddesdatabase> 
VEGETATION_ID             : 1               

FEDDES_H1                 : -0.1             !higher head for transpiration (saturation and oxygen loss)
FEDDES_H2                 : -0.25            !1st optimal head for transpiration
FEDDES_H3                 : -6.0             !2nd optimal head for transpiration
FEDDES_H4                 : -30.0            !lower head  for transpiration (wilting)
<endfeddesdatabase>

