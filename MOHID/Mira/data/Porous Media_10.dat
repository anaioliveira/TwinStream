!Start / Continuous Computation
CONTINUOUS                : 0

!Horizon Block - 0-0.3

! I have two different horizons, the surface horizon and the sub-soil horizon
!Surface Horizon
<beginhorizon>
KLB                       : 8   ! Surface soil has 3 layers, in total 0.30 m
KUB                       : 10

<beginproperty>
NAME                      : SoilID
INITIALIZATION_METHOD     : ASCII_FILE
FILENAME                  : ..\General Data\PorousMedia\SurHorizonID.dat
DEFAULTVALUE              : 1
REMAIN_CONSTANT           : 0
<endproperty>

<beginproperty>
NAME                      : Theta      !For now I am assuming that the initial value is constant for the water content
INITIALIZATION_METHOD     : CONSTANT
DEFAULTVALUE              : 0.20
<endproperty>
<endhorizon>

!Sub-soil Horizon
<beginhorizon>
KLB                       : 1   ! I am assuming that the sub-soil horizon has 7 layers with variable thickness
KUB                       : 7

<beginproperty>
NAME                      : SoilID
INITIALIZATION_METHOD     : ASCII_FILE
FILENAME                  : ..\General Data\PorousMedia\BotHorizonID.dat
DEFAULTVALUE              : 1
REMAIN_CONSTANT           : 0
<endproperty>

<beginproperty>
NAME                      : Theta      !For now I am assuming that the initial value is constant for the water content
INITIALIZATION_METHOD     : CONSTANT
DEFAULTVALUE              : 0.20
<endproperty>
<endhorizon>

